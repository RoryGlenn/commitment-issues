{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "commitment-issues machine-readable result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "command",
    "mode",
    "status",
    "exitCode",
    "summary",
    "checks",
    "findings",
    "suggestions",
    "diagnostics"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1,
      "description": "Major version of this result contract."
    },
    "command": {
      "enum": ["precommit", "prepush"]
    },
    "mode": {
      "enum": ["advisory", "blocking", "disabled"]
    },
    "status": {
      "enum": ["clean", "advisory", "blocked", "skipped", "error"]
    },
    "exitCode": {
      "type": "integer",
      "minimum": 0
    },
    "summary": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "suggestions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/suggestion"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "summary", "details"],
      "properties": {
        "id": {
          "type": "string"
        },
        "status": {
          "enum": ["passed", "advisory", "failed", "skipped"]
        },
        "summary": {
          "type": "string"
        },
        "details": {
          "type": "object"
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check", "severity", "message", "autoFixable", "details"],
      "properties": {
        "check": {
          "type": "string"
        },
        "severity": {
          "enum": ["warning", "error"]
        },
        "message": {
          "type": "string"
        },
        "autoFixable": {
          "type": "boolean"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "suggestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "description"],
      "properties": {
        "command": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "code", "message"],
      "properties": {
        "severity": {
          "enum": ["warning", "error"]
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
