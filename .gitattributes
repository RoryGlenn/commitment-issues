# Normalize line endings on checkin and force LF in the working tree so a
# Windows clone with core.autocrlf=true can't inject CRLF. This matters most
# for shell-executed git hook scripts: Git for Windows runs them via bundled
# sh, which fails on a trailing \r.
* text=auto eol=lf

# Scripts must stay LF regardless of platform.
*.mjs text eol=lf
*.sh text eol=lf
