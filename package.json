{
  "name": "commitment-issues",
  "version": "3.3.2",
  "type": "module",
  "description": "For developers who overthink every commit: advisory-first Git hook checks with optional enforcement.",
  "license": "MIT",
  "author": "Rory Glenn",
  "homepage": "https://github.com/RoryGlenn/commitment-issues#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RoryGlenn/commitment-issues.git"
  },
  "bugs": {
    "url": "https://github.com/RoryGlenn/commitment-issues/issues"
  },
  "keywords": [
    "pre-commit",
    "husky",
    "lint-staged",
    "eslint",
    "prettier",
    "git-hooks",
    "advisory",
    "non-blocking"
  ],
  "files": [
    "scripts/cli.mjs",
    "scripts/commit-fix.mjs",
    "scripts/commit-msg.mjs",
    "scripts/doctor.mjs",
    "scripts/fix-staged-js.mjs",
    "scripts/fix-staged.mjs",
    "scripts/init.mjs",
    "scripts/lib/checks.mjs",
    "scripts/lib/commit-guards.mjs",
    "scripts/lib/config.mjs",
    "scripts/lib/files.mjs",
    "scripts/lib/hooks.mjs",
    "scripts/lib/json-output.mjs",
    "scripts/lib/local-tool.mjs",
    "scripts/lib/logo.mjs",
    "scripts/lib/message.mjs",
    "scripts/lib/package-manager.mjs",
    "scripts/lib/process.mjs",
    "scripts/lib/push-base.mjs",
    "scripts/lib/runtime.mjs",
    "scripts/lib/secret-scan.mjs",
    "scripts/lib/terminal.mjs",
    "scripts/lib/ui.mjs",
    "scripts/lib/vows.mjs",
    "scripts/lib/welcome.mjs",
    "scripts/precommit.mjs",
    "scripts/prepush.mjs",
    "scripts/uninstall.mjs",
    "scripts/vows.mjs",
    "assets/advisory-push-failure.svg",
    "assets/commit-fix-success.svg",
    "assets/partially-staged-error.svg",
    "assets/precommit-suggestions-warning.svg",
    "assets/project-flowchart-dark.svg",
    "assets/project-flowchart-light.svg",
    "docs/branch-coverage.md",
    "docs/ci-recipes.md",
    "docs/compatibility.md",
    "docs/configuration.md",
    "docs/external-interface.md",
    "docs/faq.md",
    "docs/framework-recipes.md",
    "docs/how-it-works.md",
    "docs/json-output.md",
    "docs/json-output.schema.json",
    "docs/migration.md",
    "docs/monorepo.md",
    "docs/release-verification.md",
    "docs/why-before-ci.md",
    "docs/yarn-berry.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "commitment-issues": "scripts/cli.mjs"
  },
  "scripts": {
    "prepublishOnly": "npm run release:validate && npm test && npm run test:lifecycle:npm",
    "init": "node scripts/init.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "commit:fix": "node scripts/commit-fix.mjs",
    "fix:staged": "node scripts/fix-staged.mjs",
    "doctor": "node scripts/doctor.mjs",
    "states": "node tools/show-message-states.mjs",
    "benchmark:hooks": "node tools/benchmark-hook-performance.mjs",
    "release:preflight": "node tools/release-preflight.mjs",
    "release:validate": "node tools/validate-release-metadata.mjs",
    "test": "node --test test/*.test.mjs test/*.test.js",
    "test:coverage": "node scripts/run-branch-coverage.mjs",
    "coverage:badge": "node scripts/update-readme-coverage-badge.mjs",
    "coverage:check": "node scripts/update-readme-coverage-badge.mjs --check",
    "test:precommit": "node scripts/precommit.mjs",
    "test:shell-compat": "node tools/run-shell-compat-test.mjs",
    "test:lifecycle": "node scripts/run-lifecycle-test.mjs npm",
    "test:lifecycle:npm": "node scripts/run-lifecycle-test.mjs npm",
    "test:lifecycle:pnpm": "node scripts/run-lifecycle-test.mjs pnpm",
    "test:lifecycle:yarn": "node scripts/run-lifecycle-test.mjs yarn",
    "test:lifecycle:yarn-berry": "node scripts/run-lifecycle-test.mjs yarn-berry",
    "test:lifecycle:bun": "node scripts/run-lifecycle-test.mjs bun",
    "test:migration:yarn": "node tools/run-migration-lifecycle-test.mjs yarn",
    "test:smoke": "npm run test:lifecycle:npm",
    "test:smoke:pnpm": "npm run test:lifecycle:pnpm",
    "test:smoke:yarn": "npm run test:lifecycle:yarn",
    "test:smoke:yarn-berry": "npm run test:lifecycle:yarn-berry",
    "test:smoke:bun": "npm run test:lifecycle:bun"
  },
  "precommitChecks": {
    "testExempt": [
      "scripts/lib/**",
      "scripts/ci-lifecycle-smoke.mjs",
      "scripts/run-branch-coverage.mjs",
      "tools/**"
    ],
    "tone": "fun",
    "blockPushOnTestFailure": true,
    "protectedBranches": []
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "cross-spawn": "^7.0.6",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "commitment-issues": "file:",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-check": "^4.8.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "yarn": "1.22.22"
  },
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=22.11.0"
  }
}
